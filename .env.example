# ByoSync frontend — backend connection
# Copy this file to .env and set values when your backend is ready.
#
# QUICK START (backend on same machine, port 8000):
#   1. Copy: cp .env.example .env
#   2. Leave VITE_API_BASE as /api/v1 (Vite proxies /api to http://localhost:8000)
#   3. Start backend on http://localhost:8000 with routes under /api/v1
#   4. Run frontend: npm run dev  →  open http://localhost:3000
#
# BACKEND ON ANOTHER HOST (e.g. production):
#   Set VITE_API_BASE to full URL, e.g. https://api.byosync.in/v1
#   Backend must allow CORS from your frontend origin.

# Base URL for API (no trailing slash).
# - Dev with proxy: /api/v1  (Vite forwards to vite.config.ts proxy target)
# - Direct backend: http://localhost:8000/api/v1  or  https://your-api.com/api/v1
VITE_API_BASE=/api/v1

# API Key for identity:write (create identity). Send as X-API-Key header.
# Optional if backend doesn't require it or uses proxy with key.
# VITE_API_KEY=your-api-key

# JWT for identity/consent/auth APIs: frontend sends Authorization: Bearer <token>.
# Set via your auth flow into localStorage key "byosync_jwt", or leave unset.
# (Assertion token from challenge/verify is NOT sent here — it's in-memory only.)

# Optional: full URL to JWKS (Story 2.3). If unset, uses same origin + /.well-known/jwks.json
# VITE_JWKS_URL=http://localhost:8000/.well-known/jwks.json
