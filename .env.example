# ByoSync frontend — backend connection
# Copy to .env and set when your backend is ready.

# Base URL for API (no trailing slash). Dev proxy: /api/v1
# VITE_API_BASE=/api/v1

# API Key for identity:write (create). Optional if using proxy with key.
# VITE_API_KEY=your-api-key

# JWT is read from localStorage key: byosync_jwt (set by your auth flow)

# Optional: full URL to JWKS (Story 2.3). If unset, uses same origin + /.well-known/jwks.json (proxied in dev).
# VITE_JWKS_URL=http://localhost:8000/.well-known/jwks.json
